{
  "expo": {
    "name": "FitSelf",
    "slug": "fitself",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitself",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.zanderhalverson.fitself",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "FitSelf uses the camera to scan food barcodes.",
        "NSPhotoLibraryUsageDescription": "FitSelf uses your photos to set a profile picture.",
        "NSHealthShareUsageDescription": "FitSelf reads weight and activity from Apple Health to keep your stats in sync.",
        "NSHealthUpdateUsageDescription": "FitSelf can write workouts and weight to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zanderhalverson.fitself",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FitSelf uses the camera to scan food barcodes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FitSelf uses your photos to set a profile picture."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "FitSelf reads weight and activity from Apple Health to keep your stats in sync.",
          "NSHealthUpdateUsageDescription": "FitSelf can write workouts and weight to Apple Health.",
          "background": false
        }
      ],
      "react-native-health-connect",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
