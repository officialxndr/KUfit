{
  "expo": {
    "name": "Hale",
    "slug": "fitself",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hale",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "ios": {
      "bundleIdentifier": "com.zanderhalverson.hale",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Hale uses the camera to scan food barcodes.",
        "NSPhotoLibraryUsageDescription": "Hale uses your photos to set a profile picture.",
        "NSHealthShareUsageDescription": "Hale reads weight, activity, and heart rate from Apple Health to keep your stats in sync.",
        "NSHealthUpdateUsageDescription": "Hale can write workouts and weight to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.zanderhalverson.hale",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Hale uses the camera to scan food barcodes and nutrition labels.",
          "recordAudioAndroid": false
        }
      ],
      "./plugins/withoutPushEntitlement",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Hale uses your photos to set a profile picture."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Hale reads weight, activity, and heart rate from Apple Health to keep your stats in sync.",
          "NSHealthUpdateUsageDescription": "Hale can write workouts and weight to Apple Health.",
          "background": false
        }
      ],
      "react-native-health-connect",
      "expo-build-properties",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "bluetoothAlwaysPermission": "Hale connects to a compatible Bluetooth smart tape measure to log body measurements."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "healthKitEnabled": true,
      "router": {},
      "eas": {
        "projectId": "c59032f8-8809-42b2-ae16-dad26e5a46e6"
      }
    },
    "owner": "officialxndr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c59032f8-8809-42b2-ae16-dad26e5a46e6"
    }
  }
}
